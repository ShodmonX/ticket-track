def get_text(key: str, lang: str = "uz", **kwargs) -> str:
    lang = lang if lang in TRANSLATIONS else "uz"
    text = TRANSLATIONS[lang].get(key, TRANSLATIONS["uz"].get(key, ""))
    return text.format(**kwargs)
